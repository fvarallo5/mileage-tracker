<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <shortcut
        android:shortcutId="start_trip"
        android:enabled="true"
        android:icon="@mipmap/ic_launcher"
        android:shortcutShortLabel="@string/shortcut_start_trip_short"
        android:shortcutLongLabel="@string/shortcut_start_trip_long">
        <intent
            android:action="com.mileagetracker.START_TRIP"
            android:targetPackage="com.mileagetracker.mileage_tracker"
            android:targetClass="com.mileagetracker.mileage_tracker.MainActivity" />
    </shortcut>
    <shortcut
        android:shortcutId="stop_trip"
        android:enabled="true"
        android:icon="@mipmap/ic_launcher"
        android:shortcutShortLabel="@string/shortcut_stop_trip_short"
        android:shortcutLongLabel="@string/shortcut_stop_trip_long">
        <intent
            android:action="com.mileagetracker.STOP_TRIP"
            android:targetPackage="com.mileagetracker.mileage_tracker"
            android:targetClass="com.mileagetracker.mileage_tracker.MainActivity" />
    </shortcut>
</shortcuts>